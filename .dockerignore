# Exclude large training data directories
Books/
Books-MD/
ari/augmentation/

# Exclude from ari/data/ but keep required JSON files
ari/data/*.csv
ari/data/*.jsonl

# Exclude scripts (not needed at runtime)
ari/scripts/

# Exclude development/planning directories
nimbalyst-local/
skills/
context/
agents/
plans/
Competitors/
docs/

# Exclude git and other metadata
.git/
.github/
*.md
!README.md

# Keep only what's needed for the API:
# - ari/api/ (FastAPI application)
# - ari/features.py (feature extraction)
# - ari/models/ (trained model)
# - ari/data/*.json (word frequency lists)
# - ari/__init__.py (package marker)
